# Git LFS — large model checkpoints, datasets, and generated outputs
*.index filter=lfs diff=lfs merge=lfs -text
*.data-* filter=lfs diff=lfs merge=lfs -text
*.meta filter=lfs diff=lfs merge=lfs -text
*.pkl filter=lfs diff=lfs merge=lfs -text
*.pt filter=lfs diff=lfs merge=lfs -text
*.pth filter=lfs diff=lfs merge=lfs -text
*.h5 filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text

# Large tabular outputs (>1 MB typical for 250k sequences)
**/generated_sequences*.csv filter=lfs diff=lfs merge=lfs -text
**/generated_sequences_classification_results.csv filter=lfs diff=lfs merge=lfs -text
Data/**/*.csv filter=lfs diff=lfs merge=lfs -text
